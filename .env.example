# ===== CORS Configuration =====
# Comma-separated list of allowed origins for CORS requests
# Production example (ServiPal):
ALLOWED_ORIGINS=https://servi-pal.com

# Development example:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Multiple origins example:
# ALLOWED_ORIGINS=https://app.servipal.com,https://admin.servipal.com

# Whether to allow credentials (cookies, authorization headers) in CORS requests
CORS_ALLOW_CREDENTIALS=true

# ===== Application Settings =====
ENVIRONMENT=production
DEBUG=false

# ===== Frontend URL =====
API_URL=https://servipal-backend.onrender.com/api/v1

# ===== LOGFIRE =====
LOGFIRE_TOKEN=

# ===== Internal API Keys =====
INTERNAL_API_KEY=

# ===== FLUTTERWAVE =====
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_SECRET_HASH=
FLW_ENCRYPTION_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLW_PROD_SECRET_KEY=

# Flutterwave v4 (OAuth2) creds + base URL (used by Charges/Transfers/Orchestrator APIs).
# Sandbox base URL: https://developersandbox-api.flutterwave.com
# Production base URL: https://f4bexperience.flutterwave.com
FLW_TEST_CLIENT_ID=
FLW_TEST_CLIENT_SECRET=
FLW_ORCHESTRATOR_BASE_URL=

# ===== SUPABASE =====
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET_URL=

# ===== REDIS =====
# Still used by existing app features; not used by Celery broker in the RabbitMQ setup below.
UPSTASH_REDIS_REST_URL=redis://localhost:6379
# ===== PAYMENT QUEUE BACKEND =====
# supabase | dual | celery
PAYMENT_QUEUE_BACKEND=celery

# ===== CELERY =====
CELERY_ENABLED=true
CELERY_BROKER_URL=amqp://servipal:change_me@rabbitmq:5672/servipal
CELERY_RESULT_BACKEND=rpc://
CELERY_TASK_QUEUE=payment_order_creation
CELERY_RABBITMQ_QUEUE_TYPE=quorum
CELERY_TASK_DEFAULT_DELIVERY_MODE=persistent
CELERY_TASK_MAX_RETRIES=5
CELERY_TASK_RETRY_BACKOFF_MAX_SECONDS=300
CELERY_TASK_EXPIRES_SECONDS=3600
CELERY_TASK_IGNORE_RESULT=true
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=120
CELERY_TASK_TIME_LIMIT_SECONDS=180
CELERY_BROKER_HEARTBEAT=30
CELERY_BROKER_CONNECTION_TIMEOUT_SECONDS=30
CELERY_BROKER_POOL_LIMIT=10
CELERY_PUBLISH_RETRY_MAX_RETRIES=5
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=500
CELERY_WORKER_MAX_MEMORY_PER_CHILD_KB=262144
CELERY_BROKER_VISIBILITY_TIMEOUT_SECONDS=3600
CELERY_REDIS_USE_SSL=false
CELERY_REDIS_SSL_CERT_REQS=required

# ===== RABBITMQ =====
RABBITMQ_DEFAULT_USER=servipal
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_DEFAULT_VHOST=servipal
RABBITMQ_ERLANG_COOKIE=replace_with_at_least_32_random_chars
RABBITMQ_MANAGEMENT_BIND_IP=127.0.0.1
RABBITMQ_MANAGEMENT_PORT=15672

# ===== RABBITMQ DASHBOARD PROXY (online access) =====
RABBITMQ_PROXY_BIND_IP=0.0.0.0
RABBITMQ_PROXY_HTTP_PORT=80
RABBITMQ_PROXY_HTTPS_PORT=443
RABBITMQ_PROXY_NGINX_CONF_PATH=./deploy/rabbitmq-proxy/nginx.conf
RABBITMQ_PROXY_CERTS_DIR=./deploy/rabbitmq-proxy/certs
RABBITMQ_PROXY_AUTH_DIR=./deploy/rabbitmq-proxy/auth

# ===== SENTRY =====
SENTRY_DSN=
