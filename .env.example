# ===== CORS Configuration =====
# Comma-separated list of allowed origins for CORS requests
# Production example (ServiPal):
ALLOWED_ORIGINS=https://servi-pal.com

# Development example:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Multiple origins example:
# ALLOWED_ORIGINS=https://app.servipal.com,https://admin.servipal.com

# Whether to allow credentials (cookies, authorization headers) in CORS requests
CORS_ALLOW_CREDENTIALS=true

# ===== Application Settings =====
ENVIRONMENT=production
DEBUG=false

# ===== Frontend URL =====
API_URL=https://servipal-backend.onrender.com/api/v1

# ===== LOGFIRE =====
LOGFIRE_TOKEN=

# ===== Internal API Keys =====
INTERNAL_API_KEY=

# ===== FLUTTERWAVE =====
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_SECRET_HASH=
FLW_ENCRYPTION_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLW_PROD_SECRET_KEY=

# Flutterwave v4 (OAuth2) creds + base URL (used by Charges/Transfers/Orchestrator APIs).
# Sandbox base URL: https://developersandbox-api.flutterwave.com
# Production base URL: https://f4bexperience.flutterwave.com
FLW_TEST_CLIENT_ID=
FLW_TEST_CLIENT_SECRET=
FLW_ORCHESTRATOR_BASE_URL=

# ===== SUPABASE =====
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET_URL=

# ===== REDIS =====
UPSTASH_REDIS_REST_URL=redis://localhost:6379

# ===== SENTRY =====
SENTRY_DSN=
