# ===== CORS Configuration =====
# Comma-separated list of allowed origins for CORS requests
# Production example (ServiPal):
ALLOWED_ORIGINS=https://servi-pal.com

# Development example:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Multiple origins example:
# ALLOWED_ORIGINS=https://app.servipal.com,https://admin.servipal.com

# Whether to allow credentials (cookies, authorization headers) in CORS requests
CORS_ALLOW_CREDENTIALS=true

# ===== Application Settings =====
ENVIRONMENT=production
DEBUG=false

# ===== Frontend URL =====
API_URL=https://servipal-backend.onrender.com/api/v1

# ===== LOGFIRE =====
LOGFIRE_TOKEN=

# ===== Internal API Keys =====
INTERNAL_API_KEY=

# ===== FLUTTERWAVE =====
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_SECRET_HASH=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLW_PROD_SECRET_KEY=

# ===== SUPABASE =====
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET_URL=

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== SENTRY =====
SENTRY_DSN=
